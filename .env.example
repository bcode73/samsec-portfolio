# Build-time (public) — exposed to the browser bundle.
NEXT_PUBLIC_CF_BEACON_TOKEN=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Cloudflare Pages Functions secrets — set via `wrangler pages secret put <NAME>`
# or the Cloudflare dashboard. Never commit real values.
RESEND_API_KEY=
CONTACT_TO_EMAIL=
RESEND_AUDIENCE_ID=
TURNSTILE_SECRET_KEY=
